# ============================================================
# Variables de entorno para MyTodoList
# Copia este archivo como .env y completa los valores reales
# ============================================================

# Perfil Spring Boot activo: local | oracle
SPRING_PROFILES_ACTIVE=local

# Oracle DB (solo si perfil=oracle)
db_user=TU_USUARIO_DB
dbpassword=TU_PASSWORD_DB
db_url=jdbc:oracle:thin:@tudb_tp?TNS_ADMIN=/mtdrworkshop/creds
driver_class_name=oracle.jdbc.OracleDriver

# Telegram Bot (opcional)
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=tu_token_de_telegram
TELEGRAM_BOT_NAME=tu_nombre_de_bot

# DeepSeek LLM (opcional)
DEEPSEEK_API_KEY=tu_api_key_deepseek
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# UI credentials (Docker)
ui_username=admin
ui_password=cambia_este_password
